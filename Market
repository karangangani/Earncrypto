<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>AETHER Crypto Market</title>
    <script type="text/javascript" src="https://s3.tradingview.com/tv.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg-color: #0b0e14;
            --card-bg: #151a25;
            --card-hover: #1e2532;
            --text-main: #ffffff;
            --text-muted: #8b92a5;
            --accent-glow: #00f0ff;
            --positive: #22c55e;
            --negative: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Inter', sans-serif;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background-color: var(--bg-color);
            color: var(--text-main);
            overflow-x: hidden;
            display: flex;
            flex-direction: column;
            height: 100vh;
        }

        /* Header & Search */
        header {
            padding: 20px;
            background: rgba(11, 14, 20, 0.9);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 10;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        h1 {
            font-size: 24px;
            font-weight: 800;
            text-align: center;
            margin-bottom: 15px;
            background: linear-gradient(90deg, #fff, var(--accent-glow));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
        }

        .search-container {
            position: relative;
        }

        .search-bar {
            width: 100%;
            padding: 12px 16px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
            background-color: var(--card-bg);
            color: var(--text-main);
            font-size: 16px;
            outline: none;
            transition: all 0.3s ease;
        }

        .search-bar:focus {
            border-color: var(--accent-glow);
            box-shadow: 0 0 10px rgba(0, 240, 255, 0.2);
        }

        /* Main Content */
        main {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            padding-bottom: 30px;
        }

        /* AETHER Special Card */
        .aether-card {
            background: linear-gradient(145deg, #121824, #0a0d12);
            border: 1px solid var(--accent-glow);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 25px;
            box-shadow: 0 0 20px rgba(0, 240, 255, 0.15), inset 0 0 10px rgba(0, 240, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }

        .aether-card::before {
            content: '';
            position: absolute;
            top: -50%; left: -50%;
            width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(0,240,255,0.1) 0%, transparent 70%);
            animation: pulse 4s infinite linear;
            pointer-events: none;
        }

        @keyframes pulse {
            0% { transform: scale(0.95); opacity: 0.5; }
            50% { transform: scale(1.05); opacity: 1; }
            100% { transform: scale(0.95); opacity: 0.5; }
        }

        .aether-info h2 {
            font-size: 22px;
            font-weight: 800;
            color: var(--text-main);
            margin-bottom: 4px;
        }

        .aether-info p {
            font-size: 12px;
            color: var(--accent-glow);
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 600;
        }

        .aether-logo {
            width: 50px;
            height: 50px;
            background: var(--accent-glow);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            color: var(--bg-color);
            font-size: 24px;
            box-shadow: 0 0 15px var(--accent-glow);
        }

        /* Coin List */
        .coin-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .coin-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 14px 16px;
            background-color: var(--card-bg);
            border-radius: 12px;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.1s ease;
        }

        .coin-row:active, .coin-row:hover {
            background-color: var(--card-hover);
            transform: scale(0.98);
        }

        .coin-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .coin-icon {
            width: 36px;
            height: 36px;
            border-radius: 50%;
        }

        .coin-name-block {
            display: flex;
            flex-direction: column;
        }

        .coin-name {
            font-size: 15px;
            font-weight: 600;
        }

        .coin-symbol {
            font-size: 12px;
            color: var(--text-muted);
            text-transform: uppercase;
        }

        .coin-right {
            text-align: right;
            display: flex;
            flex-direction: column;
        }

        .coin-price {
            font-size: 15px;
            font-weight: 600;
        }

        .coin-change {
            font-size: 13px;
            font-weight: 600;
        }

        .change-pos { color: var(--positive); }
        .change-neg { color: var(--negative); }

        /* Chart Modal */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(5px);
            z-index: 100;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 20px;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .modal-overlay.active {
            display: flex;
            opacity: 1;
        }

        .modal-content {
            width: 100%;
            max-width: 600px;
            height: 70vh;
            background-color: var(--card-bg);
            border-radius: 16px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .modal-header {
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .modal-title {
            font-size: 18px;
            font-weight: 600;
        }

        .close-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            font-size: 24px;
            cursor: pointer;
            padding: 5px;
        }

        .chart-container {
            flex: 1;
            width: 100%;
            background: var(--bg-color);
        }

        /* Loading State */
        .loading {
            text-align: center;
            padding: 40px;
            color: var(--text-muted);
            font-size: 14px;
        }
    </style>
</head>
<body>

    <header>
        <h1>AETHER Market</h1>
        <div class="search-container">
            <input type="text" id="searchInput" class="search-bar" placeholder="Search by name or symbol (e.g. BTC)">
        </div>
    </header>

    <main>
        <div class="aether-card">
            <div class="aether-info">
                <h2>AETHER</h2>
                <p>Status: Coming Soon</p>
            </div>
            <div class="aether-logo">A</div>
        </div>

        <div class="coin-list" id="coinList">
            <div class="loading">Loading live market data...</div>
        </div>
    </main>

    <div class="modal-overlay" id="chartModal">
        <div class="modal-content">
            <div class="modal-header">
                <span class="modal-title" id="modalTitle">BTC/USDT</span>
                <button class="close-btn" onclick="closeModal()">&times;</button>
            </div>
            <div class="chart-container" id="tv_chart_container"></div>
        </div>
    </div>

    <script>
        let globalCoinData = [];
        const coinListContainer = document.getElementById('coinList');
        const searchInput = document.getElementById('searchInput');
        const chartModal = document.getElementById('chartModal');
        const modalTitle = document.getElementById('modalTitle');
        let tvWidget = null;

        // Fetch top 100 coins from CoinGecko Free API
        async function fetchMarketData() {
            try {
                const response = await fetch('https://api.coingecko.com/api/v3/coins/markets?vs_currency=usd&order=market_cap_desc&per_page=100&page=1&sparkline=false');
                if (!response.ok) throw new Error('Network response was not ok');
                
                const data = await response.json();
                globalCoinData = data;
                renderList(globalCoinData);
            } catch (error) {
                console.error("Error fetching data:", error);
                coinListContainer.innerHTML = `<div class="loading" style="color: #ef4444;">Failed to load data. Rate limit may be reached. Please wait a minute and refresh.</div>`;
            }
        }

        // Render the list of coins
        function renderList(dataToRender) {
            coinListContainer.innerHTML = '';
            
            if (dataToRender.length === 0) {
                coinListContainer.innerHTML = '<div class="loading">No coins found matching your search.</div>';
                return;
            }

            dataToRender.forEach(coin => {
                const price = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumSignificantDigits: 6 }).format(coin.current_price);
                const change = coin.price_change_percentage_24h || 0;
                const changeClass = change >= 0 ? 'change-pos' : 'change-neg';
                const changeText = change >= 0 ? `+${change.toFixed(2)}%` : `${change.toFixed(2)}%`;

                const row = document.createElement('div');
                row.className = 'coin-row';
                // Pass symbol to open chart (e.g. btc -> BTC)
                row.onclick = () => openModal(coin.symbol.toUpperCase(), coin.name);

                row.innerHTML = `
                    <div class="coin-left">
                        <img src="${coin.image}" alt="${coin.name}" class="coin-icon">
                        <div class="coin-name-block">
                            <span class="coin-name">${coin.name}</span>
                            <span class="coin-symbol">${coin.symbol}</span>
                        </div>
                    </div>
                    <div class="coin-right">
                        <span class="coin-price">${price}</span>
                        <span class="coin-change ${changeClass}">${changeText}</span>
                    </div>
                `;
                coinListContainer.appendChild(row);
            });
        }

        // Search Functionality
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase();
            const filteredData = globalCoinData.filter(coin => 
                coin.name.toLowerCase().includes(searchTerm) || 
                coin.symbol.toLowerCase().includes(searchTerm)
            );
            renderList(filteredData);
        });

        // Open TradingView Chart Modal
        function openModal(symbol, name) {
            modalTitle.innerText = `${name} (${symbol}/USDT)`;
            chartModal.classList.add('active');
            
            // Clear previous widget
            document.getElementById('tv_chart_container').innerHTML = '';

            // Map standard crypto symbols to Binance format for TradingView
            const tvSymbol = `BINANCE:${symbol}USDT`;

            tvWidget = new TradingView.widget({
                "autosize": true,
                "symbol": tvSymbol,
                "interval": "60",
                "timezone": "Etc/UTC",
                "theme": "dark",
                "style": "1",
                "locale": "en",
                "enable_publishing": false,
                "backgroundColor": "rgba(11, 14, 20, 1)",
                "gridColor": "rgba(255, 255, 255, 0.05)",
                "hide_top_toolbar": false,
                "hide_legend": false,
                "save_image": false,
                "container_id": "tv_chart_container"
            });
        }

        // Close Chart Modal
        function closeModal() {
            chartModal.classList.remove('active');
            document.getElementById('tv_chart_container').innerHTML = ''; // Destroy chart to save memory
        }

        // Close modal if clicked outside the content box
        chartModal.addEventListener('click', (e) => {
            if (e.target === chartModal) {
                closeModal();
            }
        });

        // Initialize Data Fetch
        fetchMarketData();
        
        // Auto update data every 60 seconds
        setInterval(fetchMarketData, 60000);
    </script>
</body>
</html>
